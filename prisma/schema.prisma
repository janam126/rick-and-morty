generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
}

model Episode {
  id       Int    @id
  name     String
  airDate  String
  episodeCode  String
}

model Recommendation {
  id        Int    @id @default(autoincrement())
  month     String
  episodeId Int

  @@unique([month, episodeId])
}